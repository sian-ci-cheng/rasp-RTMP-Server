# ============================================================
# 樹莓派4 RTMP 推流設定檔
# Raspberry Pi 4 RTMP Streaming Configuration
# ============================================================

# ------------------------------------------------------------
# 網路介面設定 (Network Interface)
# 樹莓派的網路孔介面名稱（通常為 eth0）
# ------------------------------------------------------------
NETWORK_INTERFACE=eth0

# ------------------------------------------------------------
# 輸入來源設定 - SangLuWoo Camera V3-365C-AR
# 請先確認攝影機的 IP 位址後修改下方 CAMERA_IP
# ------------------------------------------------------------

CAMERA_IP=192.168.8.5    # SangLuWoo V3-365C-AR（確認可用）
CAMERA_USER=admin
CAMERA_PASS=123456

# SangLuWoo V3-365C-AR RTSP URL（HiSilicon 主碼流，已確認可用）
# 串流：H.264 1920x1080 @ 25fps + AAC mono
# 注意：攝影機只允許同子網路（192.168.8.x）連線，Mac 無法直接存取
INPUT_SOURCE=rtsp://admin:123456@192.168.8.5:554/h264/ch1/main/av_stream

# RTMP 輸入來源
# INPUT_SOURCE=rtmp://192.168.1.200/live/stream

# HLS 輸入來源
# INPUT_SOURCE=http://192.168.1.300/hls/stream.m3u8

# UDP 多播輸入（IPTV 等場景）
# INPUT_SOURCE=udp://239.0.0.1:1234

# TCP 輸入
# INPUT_SOURCE=tcp://192.168.1.400:5000

# 網路介面直接擷取（pcap 模式，需安裝 libpcap）
# INPUT_SOURCE=if:eth0

# ------------------------------------------------------------
# RTSP 認證設定（若 IP 攝影機需要登入）
# ------------------------------------------------------------
RTSP_USERNAME=admin
RTSP_PASSWORD=123456

# 帶有認證的 RTSP（會覆蓋 INPUT_SOURCE 中的認證資訊）
# INPUT_SOURCE=rtsp://admin:password@192.168.8.12:554/stream

# ------------------------------------------------------------
# RTMP 輸出目標 (Output Destination)
# T100 機庫串流命名格式：rtmp://伺服器IP/live/{dock_sn}__dock
# ------------------------------------------------------------

# 樹莓派本機 nginx RTMP 伺服器（本機推流用）
RTMP_OUTPUT=rtmp://192.168.8.8/live/oBYS2OomLmSXZ6QUbqRq__dock

# 區域網路其他設備播放（使用樹莓派 eth0 IP：192.168.8.12）
# RTMP_OUTPUT=rtmp://192.168.8.12/live/oBYS2OomLmSXZ6QUbqRq__dock

# 推流至 YouTube Live（替換 YOUR-STREAM-KEY）
# RTMP_OUTPUT=rtmp://a.rtmp.youtube.com/live2/YOUR-STREAM-KEY

# 推流至 Twitch（替換 YOUR-STREAM-KEY）
# RTMP_OUTPUT=rtmp://live.twitch.tv/app/YOUR-STREAM-KEY

# 串流金鑰
STREAM_KEY=oBYS2OomLmSXZ6QUbqRq__dock

# ------------------------------------------------------------
# 多路推流設定（同時推至多個目標）
# 設定為 true 啟用，並填寫 EXTRA_OUTPUTS
# ------------------------------------------------------------
MULTI_OUTPUT=false
EXTRA_OUTPUT_1=rtmp://a.rtmp.youtube.com/live2/YOUR-YT-KEY
EXTRA_OUTPUT_2=rtmp://live.twitch.tv/app/YOUR-TWITCH-KEY

# ------------------------------------------------------------
# 影像轉碼設定 (Video Encoding)
# ------------------------------------------------------------

# 視訊編碼器
# 來源已是 H.264，直接 copy 不轉碼（CPU最低、延遲最低）
# libx264    = 軟體編碼（需要縮放/轉碼時用）
# h264_v4l2m2m = 樹莓派硬體加速（需要縮放/轉碼時用）
VIDEO_CODEC=copy

# 以下設定在 copy 模式下無效，轉碼時才生效
VIDEO_BITRATE=2500k
VIDEO_MAXRATE=3000k
VIDEO_BUFSIZE=5000k
VIDEO_SCALE=
VIDEO_FPS=25

# ------------------------------------------------------------
# 音訊轉碼設定 (Audio Encoding)
# ------------------------------------------------------------

# 音訊編碼器
# aac  = AAC 編碼（最相容）
# 來源已是 AAC，直接 copy 不轉碼
AUDIO_CODEC=copy

# 以下設定在 copy 模式下無效
AUDIO_BITRATE=128k
AUDIO_SAMPLERATE=16000

# ------------------------------------------------------------
# 串流穩定性設定 (Stream Stability)
# ------------------------------------------------------------

# 串流中斷時自動重連（秒）
RECONNECT_DELAY=5

# 最大重連次數（0 = 無限重連）
MAX_RECONNECT=0

# 連線超時（秒）
CONNECTION_TIMEOUT=10

# RTSP 傳輸協定 (tcp 較穩定，udp 延遲較低)
RTSP_TRANSPORT=tcp

# ------------------------------------------------------------
# nginx RTMP 伺服器設定
# ------------------------------------------------------------

# nginx RTMP 監聽埠
RTMP_PORT=1935

# HTTP 統計頁面埠
HTTP_STAT_PORT=8080

# 最大連線串流數
MAX_STREAMS=4

# ------------------------------------------------------------
# 日誌設定
# ------------------------------------------------------------

# 日誌等級: quiet, error, warning, info, verbose, debug
LOG_LEVEL=warning

# 日誌檔案路徑
LOG_FILE=/var/log/rtmp-stream/stream.log

# 最大日誌大小 (MB)
LOG_MAX_SIZE=100

# ------------------------------------------------------------
# 進階設定
# ------------------------------------------------------------

# FFmpeg 執行緒數（0 = 自動）
FFMPEG_THREADS=0

# 緩衝區大小（bytes）
PROBESIZE=32768
ANALYZEDURATION=0

# HLS 輸出（若需要同時提供 HLS 串流）
HLS_ENABLED=false
HLS_PATH=/tmp/hls
HLS_FRAGMENT=3
HLS_PLAYLIST=10
